# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# URL pública do site (links em e-mails, WhatsApp e notificações).
# Em produção use https://sistemairbana.com.br (ou defina FRONTEND_URL no servidor).
# Se NODE_ENV=production e FRONTEND_URL estiver vazio, o backend usa https://sistemairbana.com.br.
#
# Mesmo em desenvolvimento, o backend força https://sistemairbana.com.br em links públicos
# quando FRONTEND_URL estiver configurado com localhost — para evitar links quebrados em dev.
# Se você realmente quiser manter o comportamento antigo (links públicos apontando para localhost),
# defina na sua .env:
# ALLOW_LOCALHOST_PUBLIC_URL=true
FRONTEND_URL=http://localhost:3000
# Opcional (mesmo efeito que FRONTEND_URL):
# PUBLIC_APP_URL=https://sistemairbana.com.br

# Notificações de ponto (responsáveis): timeouts em ms — e-mail/WhatsApp rodam em background
# para não dar timeout na API se SMTP ou webhook estiverem lentos.
# NOTIFICACAO_PONTO_TIMEOUT_EMAIL_MS=12000
# NOTIFICACAO_PONTO_TIMEOUT_WHATSAPP_MS=15000
# NOTIFICACAO_PONTO_TIMEOUT_PUSH_MS=10000

# Origens permitidas para CORS (separadas por vírgula)
# Exemplo: ALLOWED_ORIGINS=http://72.60.60.118:3000,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://72.60.60.118:3000

# Database Configuration (if using direct connection)
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=application/pdf

# Storage Configuration
STORAGE_BUCKET=arquivos-obras
STORAGE_PUBLIC=true

# Google Gemini AI Configuration (para Chat de IA)
# Obtenha sua chave gratuita em: https://aistudio.google.com/apikey
# Gerencie suas chaves em: https://aistudio.google.com/app/apikeys
# Tier gratuito por modelo: gemini-2.5-flash-lite (10 RPM, 20 RPD), gemini-2.5-flash (5 RPM, 20 RPD)
# Documentação: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
# Modelo do Gemini a ser usado (padrão: gemini-2.5-flash-lite)
# Opções disponíveis na API v1beta (2025):
# - gemini-2.5-flash-lite: Modelo leve e rápido (10 RPM, ideal para chat/FAQ) ⭐ RECOMENDADO
# - gemini-2.5-flash: Modelo completo (5 RPM, para contexto maior)
# NOTA: 
# - gemini-2.0-flash-exp: Tem quota 0 no tier gratuito - NÃO USE
# - gemini-1.5-pro: Não disponível na API v1beta (descontinuado) - NÃO USE
# - gemini-1.5-flash: Pode estar descontinuado - NÃO USE
GEMINI_MODEL=gemini-2.5-flash-lite

# Web Push (VAPID) - gerar com: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_SUBJECT=mailto:suporte@irbana.com.br
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=